# MVP Level 1 — Alpaca + Finnhub + SEC (manual AI via export)

APP_ENV=development
DATABASE_URL=sqlite+aiosqlite:///./data/trading_scanner.db
CORS_ORIGINS=http://localhost:3000

# Market data (required for live scans)
ALPACA_API_KEY=
ALPACA_API_SECRET=
# Alpaca feed: sip | iex | overnight | boats (see docs/OVERNIGHT_QUOTES.md)
# Leave blank = auto overnight feed 8pm-4am ET when ALPACA_USE_OVERNIGHT_SESSION_FEED=true
ALPACA_MARKET_DATA_FEED=
ALPACA_USE_OVERNIGHT_SESSION_FEED=true
ALPACA_OVERNIGHT_FEED=overnight


# Scheduled scans off by default — manual Run scan only
SCHEDULER_ENABLED=false

# Scan filters (defaults: 100k daily volume, $50M market cap)
# SCAN_MIN_DAILY_VOLUME=100000
# SCAN_MIN_MARKET_CAP=50000000

# Finnhub free tier: avoid bursts (403/429). Metrics often 403 on free — leave false.
FINNHUB_FETCH_METRICS=false
FINNHUB_FETCH_COMPANY_NEWS=true
FINNHUB_MIN_REQUEST_INTERVAL_SEC=0

# SEC — your email required
SEC_USER_AGENT=TradingResearchScanner your-email@example.com

# Optional later
OPENAI_API_KEY=
POLYGON_API_KEY=
FMP_API_KEY=
BENZINGA_API_KEY=

ACCOUNT_BALANCE=
ACCOUNT_PDT_RESTRICTED=false
MAX_RISK_PER_TRADE=
